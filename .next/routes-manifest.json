    },
    {
      "page": "/contact",
      "regex": "^/contact(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/contact(?:/)?$"
    },
    {
      "page": "/payment/failure",
      "regex": "^/payment/failure(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/payment/failure(?:/)?$"
    },
    {
      "page": "/payment/success",
      "regex": "^/payment/success(?:/)?$",
