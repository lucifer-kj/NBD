# Shopify Storefront API Configuration
# Use your public Storefront Access Token here (X-Shopify-Storefront-Access-Token)
SHOPIFY_STORE_DOMAIN=your-store-domain.myshopify.com
SHOPIFY_STOREFRONT_ACCESS_TOKEN=your_storefront_access_token

# Shopify API Version overrides (optional, defaults to 2026-04 for storefront and 2024-04 for admin)
SHOPIFY_STOREFRONT_API_VERSION=2026-04
SHOPIFY_ADMIN_API_VERSION=2024-04

# Shopify Customer Account API Configuration
SHOPIFY_CUSTOMER_ACCOUNT_API_CLIENT_ID=your_customer_account_api_client_id
SHOPIFY_CUSTOMER_ACCOUNT_API_CLIENT_SECRET=your_customer_account_api_client_secret
SHOPIFY_CUSTOMER_ACCOUNT_API_URL=https://your-auth-domain/authentication/oauth/token
NEXT_PUBLIC_SHOPIFY_ACCOUNT_URL=https://your-account-domain

# Revalidation Secret
# Define a custom random string here (e.g., a UUID or a long random string).
# You will use this same string when setting up Shopify Webhooks to secure your revalidation endpoint.
REVALIDATION_SECRET=your_revalidation_secret

# Shopify Webhooks & Admin Access
SHOPIFY_ADMIN_ACCESS_TOKEN=shpat_your_admin_access_token
SHOPIFY_WEBHOOK_SECRET=your_shopify_webhook_secret

# Token Rotation Secrets (for secure dynamic key rotation)
SHOPIFY_TOKEN_ROTATION_SECRET=your_token_rotation_secret_bearer_token

# # Google OAuth Configuration
# NEXT_PUBLIC_GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
# GOOGLE_OAUTH_CLIENT_SECRET=your_google_oauth_client_secret

# Analytics and Scripts Tracking Configuration
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXX
NEXT_PUBLIC_GTM_ID=GTM-XXXXXX

# Core Next.js / Session settings
NEXT_PUBLIC_APP_URL=https://www.your-app-domain.com
SESSION_SECRET=your_session_secret_cookie_signing_key

# Upstash Redis / Vercel KV Configuration
KV_REST_API_URL=https://your-redis-instance.upstash.io
KV_REST_API_TOKEN=your_upstash_redis_token

# QStash (for background queue tasks)
QSTASH_TOKEN=your_qstash_token
QSTASH_CURRENT_SIGNING_KEY=sig_your_current_signing_key
QSTASH_NEXT_SIGNING_KEY=sig_your_next_signing_key

# Third-party Integrations
JUDGE_ME_API_TOKEN=your_judgeme_api_token
